{
    "name":  "@substrate/sdk",
    "version":  "1.0.0",
    "description":  "Developer SDK for Metabolic Learning / SUBSTRATE primitives (procedural memory, metabolic engine, sandbox runtime).",
    "type":  "module",
    "main":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "import":  "./dist/index.js",
                              "types":  "./dist/index.d.ts"
                          },
                    "./package.json":  "./package.json"
                },
    "files":  [
                  "dist"
              ],
    "sideEffects":  false,
    "scripts":  {
                    "build":  "tsc",
                    "dev":  "tsc --watch",
                    "typecheck":  "tsc --noEmit",
                    "clean":  "rm -rf dist",
                    "test":  "vitest"
                },
    "dependencies":  {
                         "@substrate/ai":  "workspace:*",
                         "@substrate/core":  "workspace:*",
                         "@substrate/database":  "workspace:*",
                         "@substrate/memory":  "workspace:*",
                         "@substrate/metabolic":  "workspace:*",
                         "@substrate/sandbox":  "workspace:*",
                         "@substrate/sigil":  "workspace:*"
                     },
    "devDependencies":  {
                            "typescript":  "^5.7.0",
                            "vitest":  "^2.1.0"
                        }
}
