# SUBSTRATE Unified Backup Service
# Combines backup scripts with HTTP API for centralized backup management
# ~80MB with Node.js runtime for HTTP API
FROM alpine:3.21

# Install PostgreSQL client, Node.js, and utilities
RUN apk add --no-cache \
    postgresql17-client \
    nodejs \
    openssl \
    jq \
    curl \
    bash \
    tzdata

# Create backup directories
RUN mkdir -p /backups/daily /backups/weekly /backups/monthly

# Create non-root user for security
RUN addgroup -g 1001 -S substrate && \
    adduser -S -u 1001 -G substrate substrate

# Copy backup scripts
COPY scripts/backup-substrate.sh /usr/local/bin/backup-substrate.sh
COPY scripts/restore-substrate.sh /usr/local/bin/restore-substrate.sh
COPY scripts/backup-api.js /usr/local/bin/backup-api.js
COPY scripts/backup-entrypoint-unified.sh /entrypoint.sh

# Make scripts executable
RUN chmod +x /usr/local/bin/backup-substrate.sh \
             /usr/local/bin/restore-substrate.sh \
             /usr/local/bin/backup-api.js \
             /entrypoint.sh

# Set proper ownership
RUN chown -R substrate:substrate /backups

# Expose HTTP API port
EXPOSE 8080

# Health check via HTTP API
HEALTHCHECK --interval=30s --timeout=10s --retries=3 --start-period=60s \
    CMD curl -sf http://localhost:8080/health || exit 1

ENTRYPOINT ["/entrypoint.sh"]
