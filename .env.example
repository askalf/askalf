# ============================================
# AskAlf Configuration
# ============================================
# Copy to .env and configure:  cp .env.example .env
# Generate secrets:            ./setup.sh
# Start:                       docker compose -f docker-compose.selfhosted.yml up -d
# ============================================

# --- Required ---

# Admin account (auto-created on first boot)
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=

# AI Provider (at least one required for agents)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_KEY=

# --- Security (run ./setup.sh to auto-generate) ---

POSTGRES_PASSWORD=changeme
REDIS_PASSWORD=changeme
JWT_SECRET=changeme
SESSION_SECRET=changeme
FORGE_API_KEY=changeme
CHANNEL_ENCRYPTION_KEY=changeme
INTERNAL_API_SECRET=changeme
SEARXNG_SECRET_KEY=changeme

# --- Optional: Ports ---

DASHBOARD_PORT=3001
FORGE_PORT=3005
POSTGRES_PORT=5432

# --- Optional: Agent Tuning ---

MAX_CLI_CONCURRENCY=4
MAX_EXECUTION_ITERATIONS=25
MAX_TOKENS_PER_TURN=8192
DEFAULT_MAX_COST_PER_EXECUTION=1.00
CLI_TIMEOUT=900000
CLI_MAX_TURNS=15
CLI_BUDGET_USD=0.50

# --- Optional: Anthropic OAuth (use Claude subscription for agents) ---

ANTHROPIC_OAUTH_CLIENT_ID=
ANTHROPIC_OAUTH_CLIENT_SECRET=

# --- Optional: Integrations (add keys to enable in Settings) ---

# Source Control
GITHUB_TOKEN=
GITLAB_TOKEN=
BITBUCKET_TOKEN=

# Cloud
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
GCP_SERVICE_ACCOUNT_KEY=
AZURE_SUBSCRIPTION_ID=

# CI/CD
VERCEL_TOKEN=
NETLIFY_TOKEN=

# Project Management
JIRA_API_TOKEN=
LINEAR_API_KEY=
NOTION_API_KEY=

# Monitoring
DATADOG_API_KEY=
SENTRY_DSN=
PAGERDUTY_API_KEY=

# --- Optional: Channels (add credentials to enable messaging) ---

SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
TELEGRAM_BOT_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# OpenClaw Bridge (connect OpenClaw as a channel frontend)
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=

# --- Optional: Email Notifications ---

EMAIL_PROVIDER=
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=

# --- Optional: Backup ---

BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=backups/
BACKUP_ENCRYPTION_KEY=
BACKUP_RETENTION_DAYS=7

# --- Optional: VPN Tunneling ---
# Encrypts ALL outbound agent traffic (API calls, web searches, external requests).
# Routes through Gluetun VPN proxy. Supports 30+ VPN providers.
#
# Start with VPN:
#   docker compose -f docker-compose.selfhosted.yml --profile vpn -f docker-compose.vpn.yml up -d
#
# This routes Forge, MCP-tools, and SearXNG through the VPN tunnel.
# SearXNG automatically switches to settings-vpn.yml (enables Google, Google Scholar).

VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
# For OpenVPN instead of WireGuard:
# VPN_TYPE=openvpn
# OPENVPN_USER=
# OPENVPN_PASSWORD=
VPN_SERVER_COUNTRIES=Switzerland
# Other providers: mullvad, nordvpn, surfshark, expressvpn, windscribe, cyberghost, etc.
# Full list: https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers

# --- Optional: Slim Build ---
# Skip Claude CLI and/or Codex CLI to reduce dashboard image by ~360MB
# INSTALL_CLAUDE=false
# INSTALL_CODEX=false

# --- Advanced ---

NODE_ENV=production
LOG_LEVEL=info
AUTONOMY_LOOP_ENABLED=true
BASE_URL=http://localhost:3001
