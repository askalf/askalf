# SUBSTRATE v1 Environment Configuration

# Database
DATABASE_URL=postgresql://substrate:substrate_dev@localhost:5432/orcastr8r
POSTGRES_PASSWORD=substrate_dev

# Redis
REDIS_URL=redis://localhost:6379

# LLM Providers
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# Server
PORT=3000
NODE_ENV=development

# Metabolic Loop Configuration
CRYSTALLIZE_SCHEDULE="*/15 * * * *"
EVOLVE_SCHEDULE="0 * * * *"
PROMOTE_SCHEDULE="*/30 * * * *"
DECAY_SCHEDULE="0 */12 * * *"

# Quality Gates
MIN_TRACES_FOR_CRYSTALLIZATION=5
MIN_SUCCESS_RATE_FOR_PROMOTION=0.85
BASE_DECAY_RATE=0.003

# Logging
LOG_LEVEL=info
