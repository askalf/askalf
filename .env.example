# SUBSTRATE v1 Environment Configuration

# Database
DATABASE_URL=postgresql://substrate:substrate_dev@localhost:5432/askalf
POSTGRES_PASSWORD=substrate_dev

# Redis
REDIS_URL=redis://localhost:6379

# LLM Providers
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_API_KEY_FALLBACK=sk-ant-xxx-fallback   # Optional secondary key for retries
ANTHROPIC_INTENT_API_KEY=sk-ant-xxx               # Optional: separate key for intent classification (defaults to ANTHROPIC_API_KEY)
DEMO_ANTHROPIC_API_KEY=sk-ant-xxx                 # Optional: key for unauthenticated demo chat (defaults to ANTHROPIC_API_KEY)
OPENAI_API_KEY=sk-xxx
GOOGLE_AI_KEY=                                    # Optional: Google Gemini API key

# Auth & Session Security (REQUIRED in production)
SESSION_SECRET=change-me-use-openssl-rand-base64-48   # Min 48 chars; shared by dashboard + admin-console
JWT_SECRET=change-me-use-openssl-rand-base64-32       # Min 32 chars; used for JWT token signing
ENCRYPTION_KEY=                                        # Optional: AES encryption key (defaults to JWT_SECRET if unset)
CHANNEL_ENCRYPTION_KEY=                                # Optional: hex-encoded key for channel payload encryption

# Internal API Keys (REQUIRED in production)
FORGE_API_KEY=fk_xxx                  # API key for dashboard/mcp-tools → forge internal calls
ADMIN_CONSOLE_TOKEN=act_xxx           # Bearer token for admin-console auth

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# URLs (service defaults work inside Docker Compose; override for local dev or external access)
FORGE_URL=http://forge:3005           # Base URL for forge service
BASE_URL=https://askalf.org           # Public base URL for webhooks and channel callbacks
DASHBOARD_URL=https://askalf.org      # Public dashboard URL for email links
ADMIN_EMAIL=                          # Optional: email for admin notifications

# CORS
ALLOWED_ORIGINS=https://askalf.org,https://integration.tax   # Comma-separated allowed origins for forge

# Forge Execution Tuning
MAX_EXECUTION_ITERATIONS=25
MAX_TOKENS_PER_TURN=8192
DEFAULT_MAX_COST_PER_EXECUTION=1.00
MAX_CLI_CONCURRENCY=8
CLI_TIMEOUT=900000
CLI_MAX_TURNS=15
CLI_BUDGET_USD=0.50
EXECUTION_WAIT_TIMEOUT=30000

# Autonomy Loop
AUTONOMY_LOOP_ENABLED=true

# Metabolic Loop Configuration
CRYSTALLIZE_SCHEDULE="*/15 * * * *"
EVOLVE_SCHEDULE="0 * * * *"
PROMOTE_SCHEDULE="*/30 * * * *"
DECAY_SCHEDULE="0 */12 * * *"

# Quality Gates
MIN_TRACES_FOR_CRYSTALLIZATION=5
MIN_SUCCESS_RATE_FOR_PROMOTION=0.85
BASE_DECAY_RATE=0.003

# OAuth (optional — leave blank to disable OAuth login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# Git Integration Providers (for repo linking — separate from login OAuth)
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=

# Logging
LOG_LEVEL=info
