# Dependencies
node_modules/
.pnpm-store/

# Agent worktrees (created at runtime by forge)
.worktrees/

# Build outputs
dist/
build/
*.tsbuildinfo

# Vite build output (rebuilt in Docker, never serve from git)
apps/dashboard/public/app/

# Environment (NEVER commit secrets)
.env
.env.local
.env.*.local
.env.production
.env.development
.env.staging
.env.test
# Nested .env files in app subdirectories
**/.env
**/.env.*
!**/.env.*.example
!**/.env.example

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Test coverage
coverage/
.nyc_output/

# Docker
*.pem

# Cloudflare credentials (secret - never commit)
infrastructure/cloudflared/credentials.json

# Claude Desktop MCP config (contains API keys)
apps/mcp/claude_desktop_config.json

# Backups (too large for git)
backups/

# Archive (dead weight)
archive/

# Claude Code temp files
tmpclaude-*

# Old planning docs (archived)
MASTER_PRODUCTION_PLAN.md
PRODUCTION_PLAN.md
SUBSTRATE_PROJECT_STATUS.md

# Build/cache artifacts
.cache/
.npm/

# Credentials (NEVER commit)
.claude-credentials.json

# Windows artifacts
nul

# Temp workspace scripts
workspace/

# Agent-generated docs (may be stale)
DOCKERFILE_SECURITY_AUDIT.md
FORGE_API_DOCUMENTATION.md
FORGE_API_ENDPOINTS.md

# Agent-injected system prompt (written by forge worker into worktrees)
CLAUDE.md

# Local artifacts
.deployment-history
package-lock.json
scripts/*.ps1
.claude/
apps/*/.claude/
