# Shared development Dockerfile for all TypeScript services
# No multi-stage build, no compilation — tsx watch handles everything
FROM node:22-alpine

# Build tools for native modules (isolated-vm, bcrypt, etc.)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ git \
    && rm -rf /var/lib/apt/lists/*

# Install pnpm (match version from packageManager field)
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

# Pre-install node headers + node-gyp so native module builds (bcrypt, isolated-vm)
# don't need to download at runtime (avoids fchown permission issues when caps are dropped)
RUN npm install -g node-gyp && node-gyp install

WORKDIR /app

# Entrypoint handles: pnpm install → build shared packages → run dev command
ENTRYPOINT ["/app/scripts/dev-entrypoint.sh"]
