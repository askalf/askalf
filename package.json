{
  "name": "substrate",
  "version": "1.0.0",
  "private": true,
  "description": "SUBSTRATE v1: The Perpetual Continuity Protocol - Software as Organism",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "test:integration": "vitest run --config vitest.config.ts",
    "test:integration:watch": "vitest --config vitest.config.ts",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "db:migrate": "pnpm --filter @substrate/database migrate",
    "db:generate": "pnpm --filter @substrate/database generate"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@types/node": "^20.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "pg": "^8.13.0"
  }
}
