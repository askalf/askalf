{
  "name": "askalf",
  "version": "1.0.0",
  "private": true,
  "description": "AskAlf — AI Agent Orchestration Platform",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "test:integration": "vitest run --config vitest.config.ts",
    "test:integration:watch": "vitest --config vitest.config.ts",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "db:migrate": "pnpm --filter @askalf/database migrate",
    "db:generate": "pnpm --filter @askalf/database generate"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@types/node": "^20.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "pg": "^8.20.0"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.5.6",
      "flatted": ">=3.4.0",
      "hono": ">=4.12.7",
      "@hono/node-server": ">=1.19.10",
      "minimatch": ">=10.2.3",
      "rollup": ">=4.59.0",
      "esbuild": ">=0.25.0",
      "ajv": ">=8.18.0",
      "@isaacs/brace-expansion": ">=5.0.1",
      "diff": ">=4.0.4",
      "qs": ">=6.14.2",
      "fastify": ">=5.8.1"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "hono"
      ]
    }
  }
}
